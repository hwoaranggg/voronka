# --- основное ---
BOT_TOKEN=123456:ABC-твой-токен-от-BotFather
ADMIN_IDS=123456789               # твой Telegram ID (можно несколько через запятую)
CHANNEL_ID=-1001234567890         # ID закрытого канала (бот должен быть там админом с правом приглашать)
PRICE_RUB=1500

# --- оплата картой ---
CARD_PROVIDER=yukassa             # yukassa | tribute
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_RETURN_URL=https://t.me/твой_бот
# если CARD_PROVIDER=tribute:
TRIBUTE_LINK=

# --- оплата криптой (CryptoBot) ---
CRYPTOBOT_TOKEN=
CRYPTO_FIAT=RUB

# --- прочее ---
DATABASE_URL=                     # Railway подставит сам; локально: postgresql://user:pass@host:5432/dbname
POLL_INTERVAL=30
INVITE_EXPIRE_HOURS=24
